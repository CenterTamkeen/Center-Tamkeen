# =============================================================
# Tamkeen — Environment variables template
# Copy this file to `.env.local` and fill in the real values.
# Never commit `.env.local` (it is git-ignored).
# =============================================================

# ---- Supabase ----
# Project URL and public anon key (safe to expose to the browser).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — SERVER ONLY. Never expose to the client.
# Bypasses Row Level Security (RLS).
SUPABASE_SERVICE_ROLE_KEY=

# ---- App ----
NEXT_PUBLIC_SITE_URL=http://localhost:3000
EMAIL_LOGO_URL=https://res.cloudinary.com/dabyu6chc/image/upload/v1781796565/tamkeen-transparent_gw04kk.png

# ---- Brevo SMTP ----
# Server-only transactional email settings.
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_LOGIN=
BREVO_SMTP_KEY=
BREVO_FROM_EMAIL=
BREVO_FROM_NAME=Tamkeen
EMAIL_CODE_SECRET=

# ---- Cloudinary ----
# Server-only credentials used for image uploads.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# ---- Fawry (added in Phase 8) ----
# FAWRY_MERCHANT_CODE=
# FAWRY_SECURITY_KEY=

# ---- VdoCipher (added in Phase 7) ----
# VDOCIPHER_API_SECRET=
